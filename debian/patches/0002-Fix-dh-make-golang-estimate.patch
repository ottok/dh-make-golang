+	go progressSize("go get", repodir, done)
+
+	// Run go get without arguments directly in the module directory to
+	// download all its dependencies (with -t to include the test dependencies).
+	cmd := exec.Command("go", "get", "-t")
+	cmd.Dir = repodir
